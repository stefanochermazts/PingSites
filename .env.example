APP_NAME="PingSites Monitor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://pingsites.test
APP_TIMEZONE=Europe/Rome

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pingsites
DB_USERNAME=root
DB_PASSWORD=

DB_TIMEZONE=+00:00

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.elasticemail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="monitor@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MONITOR_ALERT_RECIPIENTS=admin@example.com
ADMIN_EMAIL=admin@pingsites.local
ADMIN_NAME=Admin
ADMIN_PASSWORD=password

VITE_APP_NAME="${APP_NAME}"
